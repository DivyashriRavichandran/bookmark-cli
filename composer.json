{
    "name": "divyashriravichandran/bookmark-cli",
    "description": "A high-performance CLI bookmark indexer.",
    "type": "library",
    "license": "MIT",
    "bin": [
        "bookmarks.php"
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "require": {
        "elasticsearch/elasticsearch": "^9.4",
        "predis/predis": "^3.5"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}